# Database Configuration
# Configure these environment variables to connect to your PostgreSQL database
# If not set, the backend will run in offline mode (API works, database operations will fail)

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rental_system

# Server Configuration
PORT=3000

# JWT Configuration (for authentication)
JWT_SECRET=your-secret-key-here-change-in-production

# Node Environment
NODE_ENV=development
